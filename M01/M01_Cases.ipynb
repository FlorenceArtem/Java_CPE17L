   "source": [
    "int num1 = 100;\n",
    "int num2 = 10;\n",
    "System.out.println(\"The sum is \" + (num1 + num2));\n",
    "System.out.println(\"The diff is \" + (num1 - num2));\n",
    "System.out.println(\"The product is \" + (num1 * num2));\n",
    "System.out.println(\"The quotient is \" + (num1 / num2));"
