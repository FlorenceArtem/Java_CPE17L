   "source": [
    "int num1 = 100;\n",
    "int num2 = 90;\n",
    "int num3 = 80;\n",
    "System.out.println(\"Quiz 1 = \" + num1);\n",
    "System.out.println(\"Quiz 2 = \" + num2);\n",
    "System.out.println(\"Quiz 3 = \" + num3);\n",
    "System.out.println(\"Total = \" + (num1 + num2 + num3));\n",
    "System.out.println(\"Avg = \" + ((num1 + num2 + num3) / 3));"
   ]
